<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Fake status bar (keeps status-area spacing consistent) -->
    <View
        android:id="@+id/fake_status_bar"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:background="@color/brand_dark_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Top banner added only on launcher page -->
    <!-- Top banner (light / off-white to match Tremor page) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_banner"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/banner_bg"
        app:layout_constraintTop_toBottomOf="@id/fake_status_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">


        <!-- Center: logo + app name -->
        <LinearLayout
            android:id="@+id/banner_center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/banner_logo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/create_logo_rbg"
                android:contentDescription="@null"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/banner_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="iGest"
                android:textColor="@color/brand_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right: BLE/status icon (dark tint for visibility) -->

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content container: fill available vertical space and use weighted spacers to balance -->
    <LinearLayout
        android:id="@+id/content_holder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/top_banner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Flexible top filler — expands to absorb empty space so block stays balanced -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.2" />

        <!-- Header -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome to\niGest"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="32sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.1" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a module to begin monitoring\nwith your wearable device."
            android:textAlignment="center"
            android:textColor="@color/dark_grey"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <!-- Controlled spacer between header and cards so top area feels populated -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="36dp" />

        <!-- Tremor card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_tremor"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/brand_tremor_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_tremor"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/tremor"
                    android:contentDescription="@null"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tremor_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="OPEN TREMOR DETECTION"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/iv_tremor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tremor_sub"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="For Parkinson's Disease Monitoring"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/tremor_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="4dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Small spacer between cards -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- Anxiety card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_anxiety"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/brand_anxiety_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_anxiety"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/anxiety"
                    android:contentDescription="@null"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/anxiety_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="OPEN ANXIETY MONITORING"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/iv_anxiety"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/anxiety_sub"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="For Cognitive Impairment Support"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/anxiety_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="4dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Flexible bottom filler — expands to absorb empty space -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>