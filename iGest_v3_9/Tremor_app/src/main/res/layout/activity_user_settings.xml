<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main content (LinearLayout so ListView can scroll) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#f5f5f5"
        android:padding="16dp">

        <!-- App Title with BLE Status Circle on right -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Menu"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/textViewHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:gravity="center"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/bleStatusIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/bluetooth_off"
                android:contentDescription="@string/ble_status_off"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <!-- Material-style user card: avatar + "Logged in to" + highlighted username -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp"
            android:layout_marginBottom="12dp"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar placeholder -->
                <!-- replace existing imgUserAvatar block with this -->
                <ImageView
                    android:id="@+id/imgUserAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person_avatar"
                    android:background="@drawable/circle_bg"
                    android:padding="4dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:contentDescription="@string/user_avatar"
                    android:scaleType="centerInside"
                    android:tint="#000000" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp">

                    <TextView
                        android:id="@+id/tvLoggedInLabelSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please login with your name"
                        android:textSize="12sp"
                        android:textColor="#666" />

                    <TextView
                        android:id="@+id/tvLoggedInUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_dark_blue"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- chevron removed on request -->
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Add User button -->
        <Button
            android:id="@+id/btnAddUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add User"
            android:layout_marginBottom="8dp" />

        <!-- Row of action buttons: Select multiple | Delete (side-by-side) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnSelectMultiple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select multiple" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete"
                android:enabled="false" />
        </LinearLayout>

        <!-- Recents label -->
        <TextView
            android:id="@+id/tvRecentLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recent registrations"
            android:textSize="14sp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp" />

        <!-- ListView uses weight so it fills remaining screen and scrolls -->
        <ListView
            android:id="@+id/listViewRecentLogins"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:dividerHeight="1dp"
            android:listSelector="?android:attr/activatedBackgroundIndicator" />

        <!-- Logout button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"
        app:itemBackground="@drawable/nav_item_background"/>
</androidx.drawerlayout.widget.DrawerLayout>