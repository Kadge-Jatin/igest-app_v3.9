<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main content with scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f5f5f5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- App Title with BLE Status Circle on right -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <!-- Hamburger Menu Icon (left) -->
                <ImageView
                    android:id="@+id/menuIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_menu"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Menu"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Logo (left, next to menu) -->
                <ImageView
                    android:id="@+id/appLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/create_logo_rbg"
                    android:layout_toLeftOf="@+id/textViewHeading"
                    android:contentDescription="App Logo"/>

                <TextView
                    android:id="@+id/textViewHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="iGest"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"
                    android:gravity="center"
                    android:layout_centerInParent="true"/>

                <!--                <View-->
                <!--                    android:id="@+id/bleStatusCircle"-->
                <!--                    android:layout_width="32dp"-->
                <!--                    android:layout_height="32dp"-->
                <!--                    android:layout_alignParentRight="true"-->
                <!--                    android:layout_alignParentEnd="true"-->
                <!--                    android:layout_centerVertical="true"-->
                <!--                    android:background="@drawable/circle_red"-->
                <!--                    android:clickable="true"-->
                <!--                    android:focusable="true"-->
                <!--                    android:contentDescription="BLE Status Indicator"/>-->
                <ImageView
                    android:id="@+id/bleStatusIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/bluetooth_off"
                    android:background="@null"
                    android:adjustViewBounds="true"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/ble_status_off"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <!-- Device Address Input Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#ffffff"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Device Configuration"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp"
                        android:gravity="center" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:hint="Enter 4-digit code"
                        android:layout_gravity="center"
                        android:textAlignment="center">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="4"
                            android:digits="0123456789"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:textAlignment="center"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Connection Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/buttonConnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Connect"
                        android:textColor="#ffffff"
                        android:background="#4CAF50"
                        android:layout_marginEnd="8dp"
                        android:padding="12dp" />

                    <Button
                        android:id="@+id/buttonReset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reset"
                        android:textColor="#ffffff"
                        android:background="#f44336"
                        android:layout_marginStart="8dp"
                        android:padding="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Section (updated for Status, Device, Version) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#ffffff"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connection Status"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/textViewStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: -"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/textViewDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device: -"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/textViewVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Version: -"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Data Display Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#ffffff"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tremor Status"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp" />

                <!-- Status row -->
                <TextView
                    android:id="@+id/textViewTremorStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: -"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:fontFamily="monospace" />

                <!-- Data row -->
                <TextView
                    android:id="@+id/textViewTremorData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data: -"
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:background="#f0f0f0"
                    android:padding="8dp"
                    android:fontFamily="monospace"/>

                <!-- Raw data for debugging, very small font, no label -->
                <TextView
                    android:id="@+id/textViewTremorRaw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="8sp"
                    android:textColor="#888888"
                    android:fontFamily="monospace"
                    android:background="#f6f6f6"
                    android:padding="3dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textViewFileLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:textStyle="italic"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Live Plots Section -->
            <LinearLayout
                android:id="@+id/livePlotsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#000000"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <LinearLayout
                    android:id="@+id/livePlotsHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Live Plots"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff" />

                    <Switch
                        android:padding="3dp"
                        android:layout_marginStart="8dp"
                        android:id="@+id/toggleLivePlot"
                        android:layout_width="60dp"
                        android:layout_height="30dp"
                        android:thumb="@drawable/toggle_thumb"
                        android:track="@drawable/toggle_track"
                        android:showText="false"
                        android:checked="false"/>
                </LinearLayout>




                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/accelChart"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textViewNoLive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Caretaker Observation Section -->
            <LinearLayout
                android:id="@+id/observationSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#ffffff"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Caretaker Observation  - Data Collection"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/textViewObservedTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:gravity="center"
                    android:padding="8dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/buttonObservedRecord"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RECORD"
                    android:textAllCaps="true"
                    android:textColor="#ffffff"
                    android:padding="16dp"
                    android:enabled="false"
                    android:background="@drawable/btn_observed_record_bg" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"
        app:itemBackground="@drawable/nav_item_background" />
</androidx.drawerlayout.widget.DrawerLayout>